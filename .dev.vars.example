# Copy this file to .dev.vars for local Cloudflare Pages auth testing.
# Do not commit .dev.vars because it contains secrets.

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://127.0.0.1:8788/auth/callback
DISCORD_GUILD_ID=your_discord_server_id
ADMIN_ROLE_IDS=comma,separated,admin,role,ids
SITE_URL=http://127.0.0.1:8788